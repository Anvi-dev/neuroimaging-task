################################Task 2(A): DICOM Processing


import os
import pydicom
import numpy as np

dicom_folder = "/mnt/c/Users/sadas/Downloads/dicom/"

dicoms = []

for file in os.listdir(dicom_folder):
    path = os.path.join(dicom_folder, file)
    try:
        dcm = pydicom.dcmread(path, force=True)
        dicoms.append(dcm)
    except:
        continue

print("Total DICOM slices:", len(dicoms))


dcm0 = dicoms[0]
print("Patient ID:", dcm0.PatientID)
print("Study Date:", dcm0.StudyDate)
print("Modality:", dcm0.Modality)


dicoms_sorted = sorted(dicoms, key=lambda x: int(x.InstanceNumber))

print("First Instance:", dicoms_sorted[0].InstanceNumber)
print("Last Instance:", dicoms_sorted[-1].InstanceNumber)


######################### Task 2(B): NIfTI Processing: 

import nibabel as nib

nii_path = "/mnt/c/Users/sadas/Downloads/t1w.nii"
img = nib.load(nii_path)

print("Shape:", img.shape)
print("Data type:", img.get_data_dtype())

data = img.get_fdata()

middle_slice = data[:, :, data.shape[2] // 2]
print("Middle slice shape:", middle_slice.shape)

######################### Task 2(C): Validation:

dicom_count = len(dicoms)
nifti_depth = img.shape[2]

print("DICOM slices:", dicom_count)
print("NIfTI depth:", nifti_depth)

if dicom_count == nifti_depth:
    print("CONSISTENT")
else:
    print("MISMATCH")
